<style>
  .pod-faq-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    box-sizing: border-box;
    width: 100%;
  }
  .pod-faq-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .pod-faq-header-{{ section.id }} {
    text-align: {{ section.settings.text_align }};
    margin-bottom: {{ section.settings.heading_margin }}px;
  }
  .pod-faq-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    color: {{ section.settings.label_color }};
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }
  .pod-faq-heading-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.1;
  }
  .pod-faq-list-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_gap }}px;
  }
  .pod-faq-item-{{ section.id }} {
    background: {{ section.settings.item_bg }};
    border: 1px solid {{ section.settings.item_border }};
    border-radius: {{ section.settings.item_radius }}px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .pod-faq-item-{{ section.id }}.is-open {
    border-color: {{ section.settings.active_border }};
  }
  .pod-faq-question-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: {{ section.settings.question_padding }}px {{ section.settings.question_padding_x }}px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    width: 100%;
    background: none;
    border: none;
    text-align: left;
  }
  .pod-faq-question-text-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.question_size }}px;
    font-weight: 700;
    color: {{ section.settings.question_color }};
    line-height: 1.3;
    text-align: left;
    flex: 1;
  }
  .pod-faq-item-{{ section.id }}.is-open .pod-faq-question-text-{{ section.id }} {
    color: {{ section.settings.active_question_color }};
  }
  .pod-faq-icon-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    background: {{ section.settings.icon_bg }};
    color: {{ section.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.3s ease;
    font-weight: 300;
    line-height: 1;
  }
  .pod-faq-item-{{ section.id }}.is-open .pod-faq-icon-{{ section.id }} {
    background: {{ section.settings.active_icon_bg }};
    color: {{ section.settings.active_icon_color }};
    transform: rotate(45deg);
  }
  .pod-faq-answer-{{ section.id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.25s ease;
    padding: 0 {{ section.settings.question_padding_x }}px;
  }
  .pod-faq-item-{{ section.id }}.is-open .pod-faq-answer-{{ section.id }} {
    max-height: 600px;
    padding-bottom: {{ section.settings.answer_padding_bottom }}px;
  }
  .pod-faq-answer-text-{{ section.id }} {
    font-size: {{ section.settings.answer_size }}px;
    color: {{ section.settings.answer_color }};
    line-height: 1.7;
    margin: 0;
    border-top: 1px solid {{ section.settings.item_border }};
    padding-top: {{ section.settings.answer_padding_top }}px;
  }
  @media (max-width: 600px) {
    .pod-faq-{{ section.id }} { padding-left: 16px; padding-right: 16px; }
    .pod-faq-question-text-{{ section.id }} { font-size: {{ section.settings.question_size | minus: 2 }}px; }
  }
</style>

<div class="pod-faq-{{ section.id }}">
  <div class="pod-faq-inner-{{ section.id }}">

    <div class="pod-faq-header-{{ section.id }}">
      {%- if section.settings.label != blank -%}
        <span class="pod-faq-label-{{ section.id }}">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pod-faq-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="pod-faq-list-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <div
            class="pod-faq-item-{{ section.id }}{% if block.settings.open_by_default %} is-open{% endif %}"
            id="pod-faq-item-{{ section.id }}-{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            <button
              class="pod-faq-question-{{ section.id }}"
              aria-expanded="{% if block.settings.open_by_default %}true{% else %}false{% endif %}"
              onclick="podFaqToggle{{ section.id | replace: '-','_' }}(this)"
            >
              <span class="pod-faq-question-text-{{ section.id }}">{{ block.settings.question }}</span>
              <span class="pod-faq-icon-{{ section.id }}" aria-hidden="true">+</span>
            </button>
            <div class="pod-faq-answer-{{ section.id }}" role="region">
              <p class="pod-faq-answer-text-{{ section.id }}">{{ block.settings.answer }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  function podFaqToggle{{ section.id | replace: '-','_' }}(btn) {
    var item = btn.closest('.pod-faq-item-{{ section.id }}');
    var isOpen = item.classList.contains('is-open');

    {%- if section.settings.one_open_at_a_time -%}
    document.querySelectorAll('.pod-faq-item-{{ section.id }}').forEach(function(el) {
      el.classList.remove('is-open');
      el.querySelector('.pod-faq-question-{{ section.id }}').setAttribute('aria-expanded', 'false');
    });
    {%- endif -%}

    if (!isOpen) {
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    } else {
      item.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
    }
  }
</script>

{% schema %}
{
  "name": "POD — FAQ",
  "tag": "div",
  "class": "pod-section",
  "settings": [
    { "type": "header", "content": "🎨 الألوان" },
    { "type": "color", "id": "bg_color",            "label": "خلفية القسم",                    "default": "#0A0A0A" },
    { "type": "color", "id": "label_color",          "label": "لون التسمية",                    "default": "#FFD600" },
    { "type": "color", "id": "heading_color",        "label": "لون العنوان",                    "default": "#FFFFFF" },
    { "type": "color", "id": "item_bg",              "label": "خلفية السؤال",                   "default": "#111111" },
    { "type": "color", "id": "item_border",          "label": "حد السؤال",                      "default": "#1A1A1A" },
    { "type": "color", "id": "active_border",        "label": "حد السؤال المفتوح",              "default": "#3A2F00" },
    { "type": "color", "id": "question_color",       "label": "لون نص السؤال",                  "default": "#FFFFFF" },
    { "type": "color", "id": "active_question_color","label": "لون السؤال عند الفتح",           "default": "#FFD600" },
    { "type": "color", "id": "answer_color",         "label": "لون نص الإجابة",                 "default": "#888888" },
    { "type": "color", "id": "icon_bg",              "label": "خلفية أيقونة +",                 "default": "#1A1A1A" },
    { "type": "color", "id": "icon_color",           "label": "لون أيقونة +",                   "default": "#FFFFFF" },
    { "type": "color", "id": "active_icon_bg",       "label": "خلفية الأيقونة عند الفتح",       "default": "#FFD600" },
    { "type": "color", "id": "active_icon_color",    "label": "لون الأيقونة عند الفتح",         "default": "#0A0A0A" },
    { "type": "header", "content": "✏️ المحتوى" },
    { "type": "text",     "id": "label",              "label": "التسمية الصغيرة",               "default": "FAQ" },
    { "type": "text",     "id": "heading",            "label": "العنوان الرئيسي",               "default": "Got questions? We have answers." },
    { "type": "checkbox", "id": "one_open_at_a_time", "label": "سؤال واحد مفتوح في نفس الوقت", "default": true },
    { "type": "select",   "id": "text_align",         "label": "محاذاة العنوان",
      "options": [
        { "value": "left",   "label": "يسار" },
        { "value": "center", "label": "وسط" },
        { "value": "right",  "label": "يمين" }
      ], "default": "center" },
    { "type": "header", "content": "📐 الحجم والمساحة" },
    { "type": "range", "id": "max_width",           "label": "أقصى عرض (px)",              "min": 500, "max": 1000, "step": 40, "default": 800 },
    { "type": "range", "id": "item_gap",            "label": "مسافة بين الأسئلة (px)",     "min": 4,   "max": 24,   "step": 2,  "default": 10 },
    { "type": "range", "id": "item_radius",         "label": "تدوير الزوايا (px)",         "min": 0,   "max": 24,   "step": 2,  "default": 12 },
    { "type": "range", "id": "question_size",       "label": "حجم نص السؤال (px)",         "min": 14,  "max": 22,   "step": 1,  "default": 16 },
    { "type": "range", "id": "answer_size",         "label": "حجم نص الإجابة (px)",        "min": 13,  "max": 18,   "step": 1,  "default": 15 },
    { "type": "range", "id": "question_padding",    "label": "حشو السؤال عمودي (px)",      "min": 12,  "max": 32,   "step": 2,  "default": 20 },
    { "type": "range", "id": "question_padding_x",  "label": "حشو السؤال أفقي (px)",       "min": 16,  "max": 40,   "step": 2,  "default": 24 },
    { "type": "range", "id": "answer_padding_top",  "label": "حشو الإجابة العلوي (px)",    "min": 12,  "max": 32,   "step": 2,  "default": 16 },
    { "type": "range", "id": "answer_padding_bottom","label": "حشو الإجابة السفلي (px)",   "min": 12,  "max": 32,   "step": 2,  "default": 20 },
    { "type": "range", "id": "icon_size",           "label": "حجم أيقونة + (px)",          "min": 24,  "max": 48,   "step": 2,  "default": 32 },
    { "type": "range", "id": "label_size",          "label": "حجم التسمية (px)",            "min": 10,  "max": 16,   "step": 1,  "default": 12 },
    { "type": "range", "id": "heading_size",        "label": "حجم العنوان الأقصى (px)",    "min": 24,  "max": 56,   "step": 2,  "default": 38 },
    { "type": "range", "id": "heading_margin",      "label": "مسافة أسفل العنوان (px)",    "min": 16,  "max": 80,   "step": 4,  "default": 48 },
    { "type": "range", "id": "padding_top",         "label": "حشو علوي (px)",               "min": 40,  "max": 160,  "step": 8,  "default": 80 },
    { "type": "range", "id": "padding_bottom",      "label": "حشو سفلي (px)",               "min": 40,  "max": 160,  "step": 8,  "default": 80 },
    { "type": "range", "id": "padding_x",           "label": "حشو أفقي (px)",               "min": 16,  "max": 80,   "step": 4,  "default": 40 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "سؤال وجواب",
      "settings": [
        { "type": "text",     "id": "question",        "label": "السؤال",                    "default": "How long does delivery take?" },
        { "type": "textarea", "id": "answer",          "label": "الإجابة",                   "default": "Most orders are dispatched within 48 hours and delivered within 5-7 business days depending on your location." },
        { "type": "checkbox", "id": "open_by_default", "label": "مفتوح تلقائياً عند تحميل الصفحة", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "POD — FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How long does delivery take?", "answer": "Most orders are dispatched within 48 hours and delivered within 5-7 business days depending on your location.", "open_by_default": true } },
        { "type": "faq_item", "settings": { "question": "Can I order just one item?", "answer": "Absolutely! We have no minimum order quantity. Order as few or as many as you like." } },
        { "type": "faq_item", "settings": { "question": "What file formats do you accept for designs?", "answer": "We accept PNG, JPG, and SVG files. For best results, upload high-resolution images (at least 300 DPI)." } },
        { "type": "faq_item", "settings": { "question": "Can I return or exchange my order?", "answer": "Yes! We offer easy returns within 14 days if there is a print quality issue. Custom designs cannot be refunded unless there is a defect." } },
        { "type": "faq_item", "settings": { "question": "Do you ship internationally?", "answer": "Yes, we ship to 150+ countries worldwide with reliable tracking on every order." } }
      ]
    }
  ]
}
