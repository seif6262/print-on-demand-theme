<style>
  .pod-social-proof-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_top }};
    border-bottom: 1px solid {{ section.settings.border_bottom }};
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    box-sizing: border-box;
    width: 100%;
  }
  .pod-social-proof-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .pod-social-proof-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 600;
    color: {{ section.settings.label_color }};
    letter-spacing: 2px;
    text-transform: uppercase;
    display: block;
    text-align: center;
    margin-bottom: {{ section.settings.label_margin }}px;
    opacity: 0.7;
  }
  .pod-social-proof-items-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.items_gap }}px;
    flex-wrap: wrap;
  }
  .pod-social-proof-divider-{{ section.id }} {
    width: 1px;
    height: 40px;
    background: {{ section.settings.divider_color }};
    flex-shrink: 0;
  }
  /* Stat block */
  .pod-sp-stat-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.stat_inner_gap }}px;
    padding: {{ section.settings.stat_padding_y }}px {{ section.settings.stat_padding_x }}px;
    border-radius: {{ section.settings.stat_radius }}px;
    background: {{ section.settings.stat_bg }};
    border: 1px solid {{ section.settings.stat_border }};
    white-space: nowrap;
  }
  .pod-sp-stat-icon-{{ section.id }} {
    font-size: {{ section.settings.stat_icon_size }}px;
    line-height: 1;
  }
  .pod-sp-stat-value-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.stat_value_size }}px;
    font-weight: 800;
    color: {{ section.settings.stat_value_color }};
    line-height: 1;
    display: block;
  }
  .pod-sp-stat-label-{{ section.id }} {
    font-size: {{ section.settings.stat_label_size }}px;
    color: {{ section.settings.stat_label_color }};
    display: block;
    line-height: 1.2;
  }
  /* Logo block */
  .pod-sp-logo-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    transition: opacity 0.2s;
    filter: grayscale({{ section.settings.logo_grayscale }}%);
    padding: 0 {{ section.settings.logo_padding }}px;
  }
  .pod-sp-logo-{{ section.id }}:hover {
    opacity: 1;
    filter: grayscale(0%);
  }
  .pod-sp-logo-{{ section.id }} img {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    display: block;
    object-fit: contain;
  }
  .pod-sp-logo-text-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.logo_text_size }}px;
    font-weight: 800;
    color: {{ section.settings.logo_text_color }};
    letter-spacing: 1px;
  }
  @media (max-width: 640px) {
    .pod-social-proof-{{ section.id }} { padding-left: 16px; padding-right: 16px; }
    .pod-social-proof-divider-{{ section.id }} { display: none; }
    .pod-social-proof-items-{{ section.id }} { gap: 12px; }
    .pod-sp-stat-{{ section.id }} { padding: 10px 14px; }
  }
</style>

<div class="pod-social-proof-{{ section.id }}">
  <div class="pod-social-proof-inner-{{ section.id }}">

    {%- if section.settings.label != blank -%}
      <span class="pod-social-proof-label-{{ section.id }}">{{ section.settings.label }}</span>
    {%- endif -%}

    <div class="pod-social-proof-items-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="pod-sp-stat-{{ section.id }}" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="pod-sp-stat-icon-{{ section.id }}">{{ block.settings.icon }}</span>
            {%- endif -%}
            <div>
              <span class="pod-sp-stat-value-{{ section.id }}">{{ block.settings.value }}</span>
              {%- if block.settings.label != blank -%}
                <span class="pod-sp-stat-label-{{ section.id }}">{{ block.settings.label }}</span>
              {%- endif -%}
            </div>
          </div>
          {%- unless forloop.last -%}
            <div class="pod-social-proof-divider-{{ section.id }}"></div>
          {%- endunless -%}

        {%- elsif block.type == 'logo' -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="pod-sp-logo-{{ section.id }}" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="pod-sp-logo-{{ section.id }}" {{ block.shopify_attributes }}>
          {%- endif -%}
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 300 }}"
                alt="{{ block.settings.alt | default: 'Partner logo' }}"
                width="300" height="{{ section.settings.logo_height }}" loading="lazy"
              >
            {%- elsif block.settings.text != blank -%}
              <span class="pod-sp-logo-text-{{ section.id }}">{{ block.settings.text }}</span>
            {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
          {%- unless forloop.last -%}
            <div class="pod-social-proof-divider-{{ section.id }}"></div>
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "POD — Social Proof",
  "tag": "div",
  "class": "pod-section",
  "settings": [
    { "type": "header", "content": "🎨 الألوان" },
    { "type": "color", "id": "bg_color",        "label": "خلفية القسم",      "default": "#0D0D0D" },
    { "type": "color", "id": "border_top",       "label": "حد علوي",          "default": "#1A1A1A" },
    { "type": "color", "id": "border_bottom",    "label": "حد سفلي",          "default": "#1A1A1A" },
    { "type": "color", "id": "divider_color",    "label": "لون الفاصل",       "default": "#2A2A2A" },
    { "type": "color", "id": "stat_bg",          "label": "خلفية الإحصاء",    "default": "#151515" },
    { "type": "color", "id": "stat_border",      "label": "حد الإحصاء",       "default": "#222222" },
    { "type": "color", "id": "stat_value_color", "label": "لون الرقم",        "default": "#FFD600" },
    { "type": "color", "id": "stat_label_color", "label": "لون نص الإحصاء",  "default": "#777777" },
    { "type": "color", "id": "label_color",      "label": "لون التسمية",      "default": "#555555" },
    { "type": "color", "id": "logo_text_color",  "label": "لون نص الشعار",   "default": "#555555" },
    { "type": "header", "content": "✏️ المحتوى" },
    { "type": "text", "id": "label", "label": "نص التسمية (اتركه فارغ لإخفائه)", "default": "Trusted by creators worldwide" },
    { "type": "header", "content": "📐 الحجم والمساحة" },
    { "type": "range", "id": "max_width",      "label": "أقصى عرض (px)",             "min": 600,"max": 1400,"step": 40,"default": 1100 },
    { "type": "range", "id": "items_gap",      "label": "مسافة بين العناصر (px)",    "min": 8,  "max": 60,  "step": 4, "default": 32 },
    { "type": "range", "id": "label_size",     "label": "حجم التسمية (px)",          "min": 10, "max": 16,  "step": 1, "default": 11 },
    { "type": "range", "id": "label_margin",   "label": "مسافة أسفل التسمية (px)",   "min": 8,  "max": 40,  "step": 4, "default": 20 },
    { "type": "range", "id": "stat_icon_size", "label": "حجم إيموجي الإحصاء (px)",  "min": 16, "max": 40,  "step": 2, "default": 24 },
    { "type": "range", "id": "stat_value_size","label": "حجم رقم الإحصاء (px)",     "min": 18, "max": 40,  "step": 1, "default": 26 },
    { "type": "range", "id": "stat_label_size","label": "حجم نص الإحصاء (px)",      "min": 11, "max": 16,  "step": 1, "default": 12 },
    { "type": "range", "id": "stat_inner_gap", "label": "مسافة بين الأيقونة والنص", "min": 6,  "max": 20,  "step": 2, "default": 10 },
    { "type": "range", "id": "stat_padding_y", "label": "حشو الإحصاء عمودي (px)",   "min": 8,  "max": 24,  "step": 2, "default": 14 },
    { "type": "range", "id": "stat_padding_x", "label": "حشو الإحصاء أفقي (px)",    "min": 12, "max": 36,  "step": 2, "default": 20 },
    { "type": "range", "id": "stat_radius",    "label": "تدوير زوايا الإحصاء (px)", "min": 0,  "max": 20,  "step": 2, "default": 10 },
    { "type": "range", "id": "logo_height",    "label": "ارتفاع اللوجو (px)",        "min": 20, "max": 60,  "step": 2, "default": 32 },
    { "type": "range", "id": "logo_padding",   "label": "حشو اللوجو أفقي (px)",     "min": 0,  "max": 32,  "step": 4, "default": 8 },
    { "type": "range", "id": "logo_opacity",   "label": "شفافية اللوجو (%)",         "min": 20, "max": 100, "step": 5, "default": 50 },
    { "type": "range", "id": "logo_grayscale", "label": "تحويل اللوجو لـ Grayscale (%)","min": 0,"max": 100,"step": 10,"default": 100 },
    { "type": "range", "id": "logo_text_size", "label": "حجم نص الشعار (px)",       "min": 12, "max": 24,  "step": 1, "default": 16 },
    { "type": "range", "id": "padding_y",      "label": "حشو عمودي (px)",            "min": 16, "max": 80,  "step": 4, "default": 32 },
    { "type": "range", "id": "padding_x",      "label": "حشو أفقي (px)",             "min": 16, "max": 80,  "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "إحصاء",
      "settings": [
        { "type": "text", "id": "icon",  "label": "إيموجي", "default": "⭐" },
        { "type": "text", "id": "value", "label": "الرقم",  "default": "10k+" },
        { "type": "text", "id": "label", "label": "الوصف",  "default": "Happy Customers" }
      ]
    },
    {
      "type": "logo",
      "name": "شعار / علامة",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "صورة الشعار" },
        { "type": "text",         "id": "text",  "label": "نص بديل للشعار (لو مفيش صورة)", "default": "BRAND NAME" },
        { "type": "text",         "id": "alt",   "label": "نص بديل للصورة (accessibility)" },
        { "type": "url",          "id": "link",  "label": "رابط (اختياري)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "POD — Social Proof",
      "blocks": [
        { "type": "stat", "settings": { "icon": "📦", "value": "50k+",  "label": "Orders Fulfilled" } },
        { "type": "stat", "settings": { "icon": "⭐", "value": "4.9/5", "label": "Average Rating" } },
        { "type": "stat", "settings": { "icon": "🌍", "value": "150+",  "label": "Countries Shipped" } },
        { "type": "stat", "settings": { "icon": "⚡", "value": "48h",   "label": "Avg Dispatch Time" } }
      ]
    }
  ]
}
{% endschema %}
