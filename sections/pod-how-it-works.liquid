<style>
  .pod-hiw-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .pod-hiw-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .pod-hiw-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    color: {{ section.settings.label_color }};
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    margin-bottom: {{ section.settings.label_margin }}px;
    text-align: {{ section.settings.text_align }};
  }
  .pod-hiw-heading-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin }}px;
    line-height: 1.15;
    text-align: {{ section.settings.text_align }};
  }
  .pod-hiw-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.gap }}px;
    margin-top: {{ section.settings.grid_margin_top }}px;
  }
  .pod-hiw-step-{{ section.id }} {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    position: relative;
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
  }
  .pod-hiw-step-{{ section.id }}:hover {
    background: {{ section.settings.card_hover_bg }};
    border-color: {{ section.settings.card_hover_border }};
    transform: translateY(-3px);
  }
  .pod-hiw-number-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.number_size }}px;
    font-weight: 800;
    color: {{ section.settings.number_color }};
    line-height: 1;
    margin-bottom: {{ section.settings.number_margin }}px;
    display: block;
    opacity: 0.15;
  }
  .pod-hiw-step-title-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.step_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 {{ section.settings.title_margin }}px;
  }
  .pod-hiw-step-desc-{{ section.id }} {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 900px) {
    .pod-hiw-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .pod-hiw-grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="pod-hiw-{{ section.id }}">
  <div class="pod-hiw-inner-{{ section.id }}">

    {%- if section.settings.label != blank -%}
      <span class="pod-hiw-label-{{ section.id }}">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="pod-hiw-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="pod-hiw-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="pod-hiw-step-{{ section.id }}" {{ block.shopify_attributes }}>
            {%- if block.settings.number != blank -%}
              <span class="pod-hiw-number-{{ section.id }}">{{ block.settings.number }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="pod-hiw-step-title-{{ section.id }}">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="pod-hiw-step-desc-{{ section.id }}">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

