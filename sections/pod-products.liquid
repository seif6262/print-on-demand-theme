<style>
  .pod-products-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .pod-products-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .pod-products-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    color: {{ section.settings.label_color }};
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
    text-align: {{ section.settings.text_align }};
  }
  .pod-products-heading-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin }}px;
    line-height: 1.1;
    text-align: {{ section.settings.text_align }};
  }

  /* ── Filter Tabs ── */
  .pod-products-filters-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.filter_gap }}px;
    flex-wrap: wrap;
    justify-content: {{ section.settings.text_align }};
    margin-bottom: {{ section.settings.filter_margin }}px;
  }
  .pod-filter-btn-{{ section.id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.filter_size }}px;
    font-weight: 600;
    padding: {{ section.settings.filter_pad_y }}px {{ section.settings.filter_pad_x }}px;
    border-radius: 100px;
    border: 1px solid {{ section.settings.filter_border }};
    background: transparent;
    color: {{ section.settings.filter_text }};
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .pod-filter-btn-{{ section.id }}:hover,
  .pod-filter-btn-{{ section.id }}.active {
    background: {{ section.settings.filter_active_bg }};
    color: {{ section.settings.filter_active_text }};
    border-color: {{ section.settings.filter_active_bg }};
  }

  /* ── Product Grid ── */
  .pod-products-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  /* ── Product Card ── */
  .pod-product-card-{{ section.id }} {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    position: relative;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
    display: flex;
    flex-direction: column;
  }
  .pod-product-card-{{ section.id }}:hover {
    border-color: {{ section.settings.card_hover_border }};
    background: {{ section.settings.card_hover_bg }};
    transform: translateY(-4px);
  }
  .pod-product-card-{{ section.id }}[data-hidden="true"] {
    display: none;
  }
  .pod-product-image-{{ section.id }} {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: {{ section.settings.image_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pod-product-image-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .pod-product-card-{{ section.id }}:hover .pod-product-image-{{ section.id }} img {
    transform: scale(1.04);
  }
  .pod-product-badge-{{ section.id }} {
    position: absolute;
    top: 10px;
    left: 10px;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 10px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    z-index: 1;
  }
  .pod-product-info-{{ section.id }} {
    padding: {{ section.settings.info_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .pod-product-name-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.name_size }}px;
    font-weight: 700;
    color: {{ section.settings.name_color }};
    margin: 0;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pod-product-price-{{ section.id }} {
    font-size: {{ section.settings.price_size }}px;
    font-weight: 700;
    color: {{ section.settings.price_color }};
    font-family: 'Syne', sans-serif;
  }
  .pod-product-btn-{{ section.id }} {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    padding: 9px 16px;
    border-radius: 8px;
    background: {{ section.settings.prod_btn_bg }};
    color: {{ section.settings.prod_btn_color }};
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    margin-top: auto;
  }
  .pod-product-btn-{{ section.id }}:hover {
    background: {{ section.settings.prod_btn_hover_bg }};
    color: {{ section.settings.prod_btn_hover_color }};
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .pod-products-grid-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .pod-products-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 400px) {
    .pod-products-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.gap_mobile }}px;
    }
    .pod-product-info-{{ section.id }} {
      padding: {{ section.settings.info_padding_mobile }}px;
    }
    .pod-product-name-{{ section.id }} {
      font-size: {{ section.settings.name_size_mobile }}px;
    }
  }
</style>

{%- liquid
  assign badge_keywords = 'Best Seller,New,Popular,Sale,Hot,Limited' | split: ','
-%}

<div class="pod-products-{{ section.id }}">
  <div class="pod-products-inner-{{ section.id }}">

    {%- if section.settings.label != blank -%}
      <span class="pod-products-label-{{ section.id }}">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="pod-products-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- assign tab_blocks = section.blocks | where: 'type', 'collection_tab' -%}

    {%- if tab_blocks.size > 0 -%}
      <div class="pod-products-filters-{{ section.id }}">
        <button
          class="pod-filter-btn-{{ section.id }} active"
          onclick="podFilter{{ section.id | replace: '-', '_' }}(this, 'all')"
        >{{ section.settings.filter_all_label }}</button>

        {%- for block in tab_blocks -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- if col != blank -%}
            {%- assign tab_label = block.settings.label | default: col.title -%}
            <button
              class="pod-filter-btn-{{ section.id }}"
              onclick="podFilter{{ section.id | replace: '-', '_' }}(this, '{{ col.handle }}')"
              {{ block.shopify_attributes }}
            >{{ tab_label }}</button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="pod-products-grid-{{ section.id }}" id="pod-grid-{{ section.id }}">

      {%- for block in tab_blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        {%- if col != blank -%}
          {%- assign limit = block.settings.products_limit | default: section.settings.products_per_tab -%}

          {%- for product in col.products limit: limit -%}

            {%- comment -%} Find badge from product tags {%- endcomment -%}
            {%- assign card_badge = '' -%}
            {%- for tag in product.tags -%}
              {%- if badge_keywords contains tag -%}
                {%- assign card_badge = tag -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if card_badge == blank and block.settings.badge != blank -%}
              {%- assign card_badge = block.settings.badge -%}
            {%- endif -%}

            <div
              class="pod-product-card-{{ section.id }}"
              data-cat="{{ col.handle }}"
            >
              {%- if card_badge != blank -%}
                <span class="pod-product-badge-{{ section.id }}">{{ card_badge }}</span>
              {%- endif -%}

              <a href="{{ product.url }}" class="pod-product-image-{{ section.id }}" tabindex="-1" aria-hidden="true">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 500 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="500"
                    height="500"
                    loading="lazy"
                  >
                {%- else -%}
                  <span style="font-size:{{ section.settings.fallback_emoji_size }}px;line-height:1;">{{ block.settings.fallback_emoji | default: '🛍️' }}</span>
                {%- endif -%}
              </a>

              <div class="pod-product-info-{{ section.id }}">
                <h3 class="pod-product-name-{{ section.id }}">
                  <a href="{{ product.url }}" style="color:inherit;text-decoration:none;">{{ product.title }}</a>
                </h3>
                <span class="pod-product-price-{{ section.id }}">
                  {{ product.price_min | money }}
                  {%- if product.compare_at_price_min > product.price_min -%}
                    <del style="font-size:12px;color:{{ section.settings.compare_price_color }};font-weight:400;margin-left:6px;">{{ product.compare_at_price_min | money }}</del>
                  {%- endif -%}
                </span>
                <a href="{{ product.url }}" class="pod-product-btn-{{ section.id }}">
                  {{ section.settings.card_btn_label }} →
                </a>
              </div>
            </div>

          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</div>

<script>
  function podFilter{{ section.id | replace: '-', '_' }}(btn, cat) {
    document.querySelectorAll('.pod-filter-btn-{{ section.id }}').forEach(function(b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');

    document.querySelectorAll('#pod-grid-{{ section.id }} .pod-product-card-{{ section.id }}').forEach(function(card) {
      if (cat === 'all' || card.dataset.cat === cat) {
        card.removeAttribute('data-hidden');
      } else {
        card.setAttribute('data-hidden', 'true');
      }
    });
  }
</script>

