<style>
  .pod-whyus-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .pod-whyus-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: center;
  }
  .pod-whyus-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    color: {{ section.settings.label_color }};
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }
  .pod-whyus-heading-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 3.5vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin }}px;
    line-height: 1.15;
  }
  .pod-whyus-subtext-{{ section.id }} {
    font-size: {{ section.settings.subtext_size }}px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.65;
    margin: 0;
  }
  .pod-stats-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.stats_gap }}px;
    order: {% if section.settings.stats_position == 'left' %}-1{% else %}0{% endif %};
  }
  .pod-stat-{{ section.id }} {
    background: {{ section.settings.stat_bg }};
    border: 1px solid {{ section.settings.stat_border }};
    border-radius: {{ section.settings.stat_radius }}px;
    padding: {{ section.settings.stat_padding }}px;
    transition: transform 0.2s;
  }
  .pod-stat-{{ section.id }}:hover {
    transform: translateY(-2px);
  }
  .pod-stat-{{ section.id }}.is-accent {
    border-color: {{ section.settings.stat_accent_border }};
    background: {{ section.settings.stat_accent_bg }};
  }
  .pod-stat-value-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.stat_value_size }}px;
    font-weight: 800;
    color: {{ section.settings.accent_color }};
    line-height: 1;
    margin-bottom: 6px;
    display: block;
  }
  .pod-stat-label-{{ section.id }} {
    font-size: {{ section.settings.stat_label_size }}px;
    color: {{ section.settings.stat_label_color }};
    line-height: 1.3;
  }
  .pod-features-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.feature_gap }}px;
    margin-top: {{ section.settings.features_margin_top }}px;
  }
  .pod-feature-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.feature_inner_gap }}px;
    align-items: flex-start;
  }
  .pod-feature-icon-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: {{ section.settings.icon_radius }}px;
    background: {{ section.settings.icon_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.icon_font_size }}px;
    flex-shrink: 0;
  }
  .pod-feature-title-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-size: {{ section.settings.feature_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.feature_title_color }};
    margin: 0 0 4px;
  }
  .pod-feature-desc-{{ section.id }} {
    font-size: {{ section.settings.feature_desc_size }}px;
    color: {{ section.settings.feature_desc_color }};
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .pod-whyus-inner-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    .pod-stats-grid-{{ section.id }} {
      order: 0;
    }
  }
</style>

<div class="pod-whyus-{{ section.id }}">
  <div class="pod-whyus-inner-{{ section.id }}">

    {%- assign stat_blocks    = section.blocks | where: 'type', 'stat' -%}
    {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}

    <!-- Stats Grid -->
    <div class="pod-stats-grid-{{ section.id }}">
      {%- for block in stat_blocks -%}
        <div
          class="pod-stat-{{ section.id }}{% if block.settings.is_accent %} is-accent{% endif %}"
          {{ block.shopify_attributes }}
        >
          <span class="pod-stat-value-{{ section.id }}">{{ block.settings.value }}</span>
          <span class="pod-stat-label-{{ section.id }}">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>

    <!-- Content -->
    <div>
      {%- if section.settings.label != blank -%}
        <span class="pod-whyus-label-{{ section.id }}">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pod-whyus-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="pod-whyus-subtext-{{ section.id }}">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if feature_blocks.size > 0 -%}
        <div class="pod-features-{{ section.id }}">
          {%- for block in feature_blocks -%}
            <div class="pod-feature-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="pod-feature-icon-{{ section.id }}">{{ block.settings.icon }}</div>
              <div>
                <p class="pod-feature-title-{{ section.id }}">{{ block.settings.title }}</p>
                <p class="pod-feature-desc-{{ section.id }}">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

