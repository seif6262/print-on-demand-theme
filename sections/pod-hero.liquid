<style>
  .pod-hero-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    min-height: {{ section.settings.min_height }}vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
  }
  .pod-hero-gradient-{{ section.id }} {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse at center, {{ section.settings.gradient_color }}18 0%, transparent 70%);
    pointer-events: none;
    display: {% if section.settings.show_gradient %}block{% else %}none{% endif %};
  }
  .pod-hero-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: {{ section.settings.badge_bg }};
    border: 1px solid {{ section.settings.badge_border }};
    color: {{ section.settings.badge_color }};
    font-size: {{ section.settings.badge_size }}px;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
    position: relative;
    z-index: 1;
    letter-spacing: 0.2px;
  }
  .pod-hero-badge-dot-{{ section.id }} {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: {{ section.settings.badge_dot_color }};
    animation: pod-pulse-{{ section.id }} 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pod-pulse-{{ section.id }} {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.4); opacity: 0.6; }
  }
  .pod-hero-heading-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp({{ section.settings.heading_min }}px, {{ section.settings.heading_vw }}vw, {{ section.settings.heading_max }}px);
    line-height: 1.05;
    letter-spacing: {{ section.settings.heading_tracking }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    max-width: 900px;
    position: relative;
    z-index: 1;
  }
  .pod-hero-heading-{{ section.id }} em {
    color: {{ section.settings.accent_color }};
    font-style: normal;
  }
  .pod-hero-subtext-{{ section.id }} {
    font-size: {{ section.settings.subtext_size }}px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.65;
    max-width: {{ section.settings.subtext_max_width }}px;
    margin: 0 0 {{ section.settings.subtext_margin_bottom }}px;
    position: relative;
    z-index: 1;
    font-weight: 400;
  }
  .pod-hero-buttons-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.btn_gap }}px;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .pod-hero-btn-primary-{{ section.id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.btn_size }}px;
    font-weight: 700;
    background: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_color }};
    padding: {{ section.settings.btn_padding_y }}px {{ section.settings.btn_padding_x }}px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
    border: 2px solid {{ section.settings.btn_primary_bg }};
  }
  .pod-hero-btn-primary-{{ section.id }}:hover {
    background: {{ section.settings.btn_primary_hover }};
    border-color: {{ section.settings.btn_primary_hover }};
    transform: translateY(-2px);
    color: {{ section.settings.btn_primary_color }};
  }
  .pod-hero-btn-secondary-{{ section.id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.btn_size }}px;
    font-weight: 500;
    background: transparent;
    color: {{ section.settings.btn_secondary_color }};
    padding: {{ section.settings.btn_padding_y }}px {{ section.settings.btn_padding_x }}px;
    border-radius: 100px;
    border: 2px solid {{ section.settings.btn_secondary_border }};
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .pod-hero-btn-secondary-{{ section.id }}:hover {
    background: rgba(255,255,255,0.06);
    transform: translateY(-2px);
    color: {{ section.settings.btn_secondary_color }};
  }
  @media (max-width: 600px) {
    .pod-hero-buttons-{{ section.id }} {
      flex-direction: column;
      width: 100%;
    }
    .pod-hero-btn-primary-{{ section.id }},
    .pod-hero-btn-secondary-{{ section.id }} {
      width: 100%;
      text-align: center;
    }
  }
</style>

<div class="pod-hero-{{ section.id }}">
  <div class="pod-hero-gradient-{{ section.id }}"></div>

  {%- if section.settings.badge_text != blank -%}
    <div class="pod-hero-badge-{{ section.id }}">
      <span class="pod-hero-badge-dot-{{ section.id }}"></span>
      {{ section.settings.badge_text }}
    </div>
  {%- endif -%}

  <h1 class="pod-hero-heading-{{ section.id }}">
    {%- if section.settings.hero_line1 != blank -%}
      {{ section.settings.hero_line1 }}
    {%- endif -%}
    {%- if section.settings.hero_highlight != blank -%}
      <em>{{ section.settings.hero_highlight }}</em>
    {%- endif -%}
    {%- if section.settings.hero_line2 != blank -%}
      {{ section.settings.hero_line2 }}
    {%- endif -%}
  </h1>

  {%- if section.settings.subtext != blank -%}
    <p class="pod-hero-subtext-{{ section.id }}">{{ section.settings.subtext }}</p>
  {%- endif -%}

  <div class="pod-hero-buttons-{{ section.id }}">
    {%- if section.settings.btn_primary_text != blank -%}
      <a href="{{ section.settings.btn_primary_url }}" class="pod-hero-btn-primary-{{ section.id }}">
        {{ section.settings.btn_primary_text }}
      </a>
    {%- endif -%}
    {%- if section.settings.btn_secondary_text != blank -%}
      <a href="{{ section.settings.btn_secondary_url }}" class="pod-hero-btn-secondary-{{ section.id }}">
        {{ section.settings.btn_secondary_text }}
      </a>
    {%- endif -%}
  </div>
</div>

