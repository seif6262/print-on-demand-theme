      "id": "btn_size",
      "label": "حجم خط الزرار (px)",
      "min": 13,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "btn_padding_x",
      "label": "حشو الزرار أفقي (px)",
      "min": 20,
      "max": 64,
      "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "btn_padding_y",
      "label": "حشو الزرار عمودي (px)",
      "min": 10,
      "max": 28,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "inner_padding_x",
      "label": "حشو البنر أفقي (px)",
      "min": 24,
      "max": 100,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "inner_padding_y",
      "label": "حشو البنر عمودي (px)",
      "min": 24,
      "max": 100,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "gap",
