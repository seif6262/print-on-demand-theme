    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "خلفية الزرار",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "لون نص الزرار",
      "default": "#FFD600"
    },
    {
      "type": "header",
      "content": "✏️ المحتوى"
    },
    {
      "type": "text",
      "id": "heading",
