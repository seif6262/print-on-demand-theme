      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "حجم العنوان الأقصى (px)",
      "min": 20,
      "max": 56,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_margin",
      "label": "مسافة أسفل العنوان (px)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "حجم النص الفرعي (px)",
