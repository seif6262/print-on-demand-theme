<style>
  .pod-footer-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .pod-footer-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .pod-footer-logo-{{ section.id }} {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: {{ section.settings.logo_size }}px;
    color: {{ section.settings.logo_color }};
    text-decoration: none;
  }
  .pod-footer-logo-{{ section.id }} em {
    color: {{ section.settings.logo_accent }};
    font-style: normal;
  }
  .pod-footer-links-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.links_gap }}px;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .pod-footer-links-{{ section.id }} a {
    font-size: {{ section.settings.link_size }}px;
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s;
  }
  .pod-footer-links-{{ section.id }} a:hover {
    color: {{ section.settings.link_hover_color }};
  }
  .pod-footer-copy-{{ section.id }} {
    font-size: {{ section.settings.copy_size }}px;
    color: {{ section.settings.copy_color }};
    margin: 0;
  }
  @media (max-width: 640px) {
    .pod-footer-inner-{{ section.id }} {
      flex-direction: column;
      text-align: center;
    }
    .pod-footer-links-{{ section.id }} {
      justify-content: center;
    }
  }
</style>

<footer class="pod-footer-{{ section.id }}">
  <div class="pod-footer-inner-{{ section.id }}">

    <a href="/" class="pod-footer-logo-{{ section.id }}">
      {{ section.settings.logo_word1 }}&nbsp;<em>{{ section.settings.logo_word2 }}</em>
    </a>

    {%- assign link_blocks = section.blocks | where: 'type', 'link' -%}
    {%- if link_blocks.size > 0 -%}
      <ul class="pod-footer-links-{{ section.id }}">
        {%- for block in link_blocks -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}">{{ block.settings.label }}</a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.copyright != blank -%}
      <p class="pod-footer-copy-{{ section.id }}">{{ section.settings.copyright }}</p>
    {%- endif -%}

  </div>
</footer>

{% schema %}
{
  "name": "POD — Footer",
  "tag": "div",
  "class": "pod-section",
  "settings": [
    {
      "type": "header",
      "content": "🎨 الألوان"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "لون الخلفية",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "لون الحد العلوي",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "logo_color",
      "label": "لون الشعار",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "logo_accent",
      "label": "لون الكلمة المميزة في الشعار",
      "default": "#FFD600"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "لون الروابط",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "لون الروابط عند التمرير",
      "default": "#FFD600"
    },
    {
      "type": "color",
      "id": "copy_color",
      "label": "لون نص الحقوق",
      "default": "#444444"
    },
    {
      "type": "header",
      "content": "✏️ المحتوى"
    },
    {
      "type": "text",
      "id": "logo_word1",
      "label": "الشعار — الكلمة الأولى",
      "default": "YOUR"
    },
    {
      "type": "text",
      "id": "logo_word2",
      "label": "الشعار — الكلمة المميزة",
      "default": "BRAND"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "نص حقوق النشر",
      "default": "© 2024 Your Brand. All rights reserved."
    },
    {
      "type": "header",
      "content": "📐 الحجم والمساحة"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "أقصى عرض (px)",
      "min": 800,
      "max": 1400,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "حجم الشعار (px)",
      "min": 14,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "link_size",
      "label": "حجم خط الروابط (px)",
      "min": 12,
      "max": 18,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "copy_size",
      "label": "حجم خط الحقوق (px)",
      "min": 11,
      "max": 16,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "links_gap",
      "label": "مسافة بين الروابط (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "حشو عمودي (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "حشو أفقي (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "رابط",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "نص الرابط",
          "default": "Privacy Policy"
        },
        {
          "type": "url",
          "id": "url",
          "label": "الرابط"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "POD — Footer",
      "blocks": [
        { "type": "link", "settings": { "label": "Privacy Policy" } },
        { "type": "link", "settings": { "label": "Terms of Service" } },
        { "type": "link", "settings": { "label": "Contact Us" } }
      ]
    }
  ]
}
{% endschema %}
